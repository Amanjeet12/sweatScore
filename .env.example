# =====================================================================
# SweatScore App — client-side environment variables
# =====================================================================
# Copy this file to `.env.local` and fill in the values below.
# `.env.local` is gitignored and never committed.
#
# These EXPO_PUBLIC_* values are bundled into the JS at build time and
# are visible in the shipped binary. Do NOT put server-only secrets here.
# Server-side secrets (SMTP, MailerLite, Trigger.dev, Endurance Zone,
# etc.) live in the Convex / Trigger.dev dashboards — see
# TECHNICAL_DOCUMENTATION.md §16 for the full list.
# =====================================================================

# --- Convex backend ---------------------------------------------------
# Convex deployment URL + name. Get from `bunx convex dev` first run,
# or from dashboard.convex.dev → Project → Settings.
CONVEX_DEPLOYMENT=
EXPO_PUBLIC_CONVEX_URL=

# Production values (uncomment + set when running `bunx convex deploy`):
# CONVEX_DEPLOYMENT=
# EXPO_PUBLIC_CONVEX_URL=

# --- Test account override -------------------------------------------
# When this email is used at login, the OTP is read from
# TEST_ACCOUNT_OTP (Convex env) instead of being emailed. Used by
# App Store / Play Store reviewers. Keep blank in dev unless needed.
EXPO_PUBLIC_TEST_ACCOUNT_EMAIL=

# --- RevenueCat (subscriptions / IAP) --------------------------------
# Public API keys from app.revenuecat.com → Project → API keys.
# These are intended to be embedded in the client.
EXPO_PUBLIC_REVENUECAT_IOS_API_KEY= appl_iypIRktsrOsKZftFTySkKEJofHA
EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY= goog_iQYrLnNfnxkvAXkjAJLPIxWcPoq

# --- Facebook / Instagram Stories sharing ----------------------------
# Facebook App ID, required by react-native-share to post to
# Instagram Stories and Facebook Stories. Get from
# developers.facebook.com → App → Settings → Basic → App ID.
EXPO_PUBLIC_FB_APP_ID=

# --- Android: Firebase google-services.json (build-time only) --------
# Absolute path on the build machine to the google-services.json file.
# Used by app.config.ts at `eas build` time for Android. Not needed
# for iOS or for local Expo Go dev. Store the JSON file outside the
# repo and point this variable at it on the build machine / EAS secret.
# GOOGLE_SERVICES_JSON=/absolute/path/to/google-services.json
