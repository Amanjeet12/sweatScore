{
  "cli": {
    "version": ">= 16.2.1",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "channel": "development",
      "ios": {
        "image": "latest"
      }
    },
    "preview": {
      "distribution": "internal",
      "channel": "preview",
      "environment": "preview",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "image": "latest"
      }
    },
    "preview-store": {
      "extends": "preview",
      "distribution": "store",
      "autoIncrement": true,
      "channel": "preview",
      "environment": "preview",
      "ios": {
        "image": "latest"
      }
    },
    "production": {
      "channel": "production",
      "environment": "production",
      "autoIncrement": true,
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "image": "latest"
      }
    }
  },
  "submit": {
    "preview-store": {
      "ios": {
        "ascAppId": "6744372181"
      }
    },
    "production": {
      "ios": {
        "ascAppId": "6744372181"
      }
    }
  }
}
