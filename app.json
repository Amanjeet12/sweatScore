{
  "name": "SweatScore",
  "slug": "sweatscore-app",
  "owner": "sweatscore",
  "version": "1.1.7",
  "scheme": "sweatscore-app",
  "newArchEnabled": false,
  "web": {
    "bundler": "metro",
    "output": "static",
    "favicon": "./assets/favicon.png"
  },
  "notification": {
    "iosDisplayInForeground": true
  },
  "plugins": [
    "expo-router",
    "expo-secure-store",
    "expo-video",
    "expo-camera",
    [
      "expo-media-library",
      {
        "savePhotosPermission": "Allow SweatScore to save videos to your photo library.",
        "isAccessMediaLocationEnabled": false
      }
    ],
    [
      "react-native-share",
      {
        "ios": [
          "fb",
          "instagram",
          "instagram-stories",
          "facebook-stories",
          "tiktoksharesdk"
        ],
        "android": [
          "com.instagram.android",
          "com.facebook.katana",
          "com.zhiliaoapp.musically"
        ]
      }
    ],
    "expo-localization",
    "expo-font",
    "react-native-health",
    "./plugins/with-healthkit-capability",
    "expo-health-connect",
    [
      "expo-splash-screen",
      {
        "backgroundColor": "#FFFFFF",
        "image": "./assets/splash-icon-dark.png",
        "dark": {
          "image": "./assets/splash-icon-light.png",
          "backgroundColor": "#000000"
        },
        "imageWidth": 200
      }
    ],
    [
      "expo-build-properties",
      {
        "android": {
          "compileSdkVersion": 35,
          "targetSdkVersion": 35,
          "minSdkVersion": 26
        }
      }
    ],
    "./plugins/with-xcode26-fmt-fix",
    [
      "expo-image-picker",
      {
        "photosPermission": "Allow $(PRODUCT_NAME) to access your photos."
      }
    ]
  ],
  "experiments": {
    "typedRoutes": true,
    "tsconfigPaths": true
  },
  "orientation": "portrait",
  "userInterfaceStyle": "light",
  "assetBundlePatterns": [
    "**/*"
  ],
  "ios": {
    "supportsTablet": false,
    "bundleIdentifier": "com.sweatscore.sweatscoreapp",
    "infoPlist": {
      "ITSAppUsesNonExemptEncryption": false,
      "LSApplicationQueriesSchemes": [
        "fb",
        "instagram",
        "instagram-stories",
        "facebook-stories",
        "tiktoksharesdk",
        "fb",
        "instagram",
        "instagram-stories",
        "facebook-stories",
        "tiktoksharesdk"
      ]
    },
    "icon": {
      "dark": "./assets/ios-dark.png",
      "light": "./assets/ios-light.png",
      "tinted": "./assets/ios-tinted.png"
    },
    "userInterfaceStyle": "light"
  },
  "android": {
    "adaptiveIcon": {
      "foregroundImage": "./assets/adaptive-icon.png",
      "backgroundColor": "#FFEEE1"
    },
    "package": "com.sweatscore.sweatscoreapp",
    "permissions": [
      "android.permission.health.READ_STEPS",
      "android.permission.health.READ_HEART_RATE",
      "android.permission.CAMERA",
      "android.permission.RECORD_AUDIO",
      "android.permission.READ_EXTERNAL_STORAGE",
      "android.permission.WRITE_EXTERNAL_STORAGE"
    ],
    "blockedPermissions": [
      "android.permission.READ_MEDIA_IMAGES",
      "android.permission.READ_MEDIA_VIDEO",
      "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
      "android.permission.READ_MEDIA_IMAGES",
      "android.permission.READ_MEDIA_VIDEO",
      "android.permission.READ_MEDIA_VISUAL_USER_SELECTED"
    ],
    "userInterfaceStyle": "light",
    "googleServicesFile": "/Users/expo/workingdir/eas-environment-secrets/02f7c32724b02c5d6422b5b30ffad259e2b6c4c4f6adae585a4195135112ea1d"
  },
  "extra": {
    "router": {
      "origin": false
    },
    "eas": {
      "projectId": "685b5f2b-f462-4de3-ba5e-d33edcc8085a"
    }
  },
  "runtimeVersion": {
    "policy": "appVersion"
  },
  "updates": {
    "url": "https://u.expo.dev/685b5f2b-f462-4de3-ba5e-d33edcc8085a"
  },
  "sdkVersion": "52.0.0",
  "platforms": [
    "ios",
    "android",
    "web"
  ],
  "androidStatusBar": {
    "backgroundColor": "#FFFFFF"
  }
}
